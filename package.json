{
  "name": "hometech-bielefeld",
  "private": true,
  "version": "0.1.0",
  "description": "HomeTech Bielefeld webshop homepage slice.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "runtime:start": "sh scripts/runtime-start.sh",
    "runtime:stop": "sh scripts/runtime-stop.sh",
    "runtime:restart": "sh scripts/runtime-restart.sh",
    "runtime:status": "sh scripts/runtime-status.sh",
    "public:start": "sh scripts/public-start.sh",
    "public:stop": "sh scripts/public-stop.sh",
    "public:restart": "sh scripts/public-restart.sh",
    "public:status": "sh scripts/public-status.sh",
    "typecheck": "tsc --noEmit",
    "assets:prepare": "node scripts/prepare-local-assets.mjs",
    "images:process": "node scripts/product-images/run-pipeline.mjs",
    "images:demo-batch": "node scripts/product-images/run-pipeline.mjs scripts/product-images/batches/current-assortment-demo.json",
    "db:seed-homepage": "node scripts/seed-homepage-catalog.mjs",
